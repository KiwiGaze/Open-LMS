# URL the Next.js server proxies API calls to (server-side rewrite).
API_BASE_URL=http://localhost:3000

# Public base URL the browser uses to reach this Next.js app.
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Public base URL the browser uses for the API. Defaults to the rewrites in next.config.mjs.
NEXT_PUBLIC_API_BASE_URL=/api/v1
