{
  "name": "@openlms/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./openapi": {
      "types": "./src/openapi.ts",
      "default": "./src/openapi.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch src/server.ts",
    "dispatch:outbox": "tsx scripts/dispatch-outbox.ts",
    "dispatch:notifications": "tsx scripts/dispatch-notifications.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src scripts tests",
    "test": "vitest run",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "^0.19.10",
    "@openlms/ai": "workspace:*",
    "@openlms/contracts": "workspace:*",
    "@openlms/core": "workspace:*",
    "hono": "^4.12.18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
